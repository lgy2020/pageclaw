{
  "manifest_version": 3,
  "name": "PageClaw",
  "version": "0.1.0",
  "description": "AI-powered browser automation. Type @ai in the address bar and tell the AI what to do. Supports Google, YouTube, Bilibili, Amazon, and more.",
  "permissions": ["activeTab", "scripting", "storage", "omnibox", "debugger"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "omnibox": {
    "keyword": "ai"
  },
  "action": {
    "default_title": "PageClaw",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
