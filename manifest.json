{
  "manifest_version": 3,
  "name": "PageClaw",
  "version": "0.12.0",
  "description": "AI-powered browser automation. Type @ai in the address bar and tell the AI what to do. Supports Google, YouTube, Bilibili, Amazon, and more.",
  "icons": {
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "scripting", "storage", "omnibox", "debugger", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "worker/background.js",
    "type": "module"
  },
  "omnibox": {
    "keyword": "ai"
  },
  "action": {
    "default_title": "PageClaw",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["inject-overlay.js"],
    "run_at": "document_start"
  }]
}
